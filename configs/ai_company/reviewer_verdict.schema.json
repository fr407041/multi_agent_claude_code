{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Company Reviewer Verdict",
  "type": "object",
  "required": [
    "task_id",
    "review_status",
    "owner_role",
    "verdict",
    "evidence",
    "repair_action",
    "replan_required"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "review_status": {
      "type": "string",
      "enum": ["COMPLETE", "INCOMPLETE"]
    },
    "owner_role": { "type": "string", "minLength": 1 },
    "verdict": {
      "type": "string",
      "enum": [
        "ACCEPTED",
        "REPAIR_REQUIRED",
        "REPLAN_REQUIRED",
        "FALSE_SUCCESS_BLOCKED",
        "SCHEMA_INVALID",
        "MISSING_ARTIFACT"
      ]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "repair_action": { "type": "string" },
    "replan_required": { "type": "boolean" }
  },
  "additionalProperties": false
}
