      "recovery_policy": {
        "overflow": "summarize meeting state and reduce agenda",
        "router_error": "retry once then escalate",
        "false_success": "mark meeting invalid",
        "timeout": "emit MEETING_NEEDS_REPLAN"
      }
    },
