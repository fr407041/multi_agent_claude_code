{
  "min_words": 45,
  "max_words": 170,
  "min_bullets": 3,
  "min_numeric_mentions": 4,
  "require_conclusion_line": true,
  "takeaway_pattern": "conditional go|not clean go|no-go|go/no-go",
  "required_keywords_all": [
    "conditional go",
    "blocker",
    "evidence",
    "rollback",
    "uncertainty",
    "router",
    "overflow"
  ],
  "required_patterns": [
    "42\\s+unit",
    "11\\s+(?:passed\\s+)?backend",
    "4\\s+of\\s+5",
    "15(?:\\s+minutes|-minute)",
    "B1",
    "B2"
  ]
}
